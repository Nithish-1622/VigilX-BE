		{
			"name": "1. Authentication",
			"item": [
				{
					"name": "Login (Officer User)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access) {",
									"    pm.collectionVariables.set(\"authToken\", jsonData.access);",
									"    console.log(\"Saved authToken to collection variables.\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"officer1\",\n  \"password\": \"Officer123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"login",
								""
							]
						},
						"description": "Authenticates the user against PostgreSQL users table and returns JWT tokens."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refresh\": \"<YOUR_REFRESH_TOKEN>\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/refresh/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"refresh",
								""
							]
						}
					},
					"response": []
				}
			]
		},
